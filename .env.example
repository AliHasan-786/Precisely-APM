# ============================================================
# Precisely PM-Intel Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The app runs in demo mode (mock data) without any of these.
# ============================================================

# ------ Anthropic AI ----------------------------------------
# Required for live AI analysis and PRD generation.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ------ Supabase (optional) ---------------------------------
# If not set, the app uses in-memory mock data instead.
# Create a project at: https://app.supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ Slack Notifications (optional) ---------------------
# Weekly brief will be posted to this webhook URL.
# Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------ Backend API -----------------------------------------
# URL of the Python FastAPI backend.
# Frontend Next.js API routes proxy requests here.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------ Frontend (set automatically by Next.js) -------------
# No action needed — kept here for reference.
NODE_ENV=development
